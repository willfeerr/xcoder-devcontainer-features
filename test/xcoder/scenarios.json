{
  "default": {
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "features": {
      "xcoder": {}
    }
  },
  "full-control-no-autostart": {
    "image": "debian:bookworm",
    "features": {
      "xcoder": {
        "permission": "full-control",
        "autoStart": false,
        "browserlessRequired": true
      }
    }
  }
}
