{
  "name": "Projeto com XCoder",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/willfeerr/xcoder-devcontainer-features/xcoder:1": {
      "permission": "ask",
      "autoStart": true,
      "xcoderRef": "a905425aeb5076894dfece0bd42b9e692f90895a",
      "browserMode": "required"
    }
  },
  "containerEnv": {
    "SKRBE_BRIDGE_URL": "${localEnv:SKRBE_BRIDGE_URL}",
    "SKRBE_BRIDGE_TOKEN": "${localEnv:SKRBE_BRIDGE_TOKEN}",
    "SKRBE_AGENT_ID": "${localEnv:SKRBE_AGENT_ID}",
    "BROWSERLESS_URL": "${localEnv:BROWSERLESS_URL}",
    "BROWSERLESS_TOKEN": "${localEnv:BROWSERLESS_TOKEN}",
    "SSH_AUTH_SOCK": "/tmp/host-ssh-agent.sock"
  }
}
